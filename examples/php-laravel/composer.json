{
  "name": "harmont/example-laravel",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.11",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": { "App\\": "app/" }
  },
  "autoload-dev": {
    "psr-4": { "Tests\\": "tests/" }
  },
  "config": {
    "platform": { "php": "8.3" }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
