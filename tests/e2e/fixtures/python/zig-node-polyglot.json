          "CI": "true"
        },
        "step": {
          "cmd": "cd zig-b && zig build test",
          "key": "zig-b-test",
          "label": ":zig: zig-b test"
        }
      },
      {
        "env": {
          "CI": "true"
        },
        "step": {
          "cache": {
            "env_keys": [],
